# =============================================================================
# Booey - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# ⚠️  NEVER commit .env.local to git!
# ⚠️  NEVER prefix secret keys with NEXT_PUBLIC_ (exposes them to the browser)
# =============================================================================

# --- Supabase ---
# These are safe to expose client-side (RLS protects your data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# --- Anthropic (Claude API) ---
# ⚠️  CRITICAL: Server-side ONLY. Never use NEXT_PUBLIC_ prefix!
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Upstash Redis (Rate Limiting) ---
# Required when rate limiting is enabled (Phase 4+)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# --- Cost Protection ---
# Daily budget cap in USD (blocks requests when exceeded)
# DAILY_BUDGET_USD=5.00
# Emergency kill switch — set to "true" to block all AI requests instantly
# EMERGENCY_STOP=false
# ntfy.sh topic for cost alerts (use a random suffix for security)
# NTFY_TOPIC=booey-cost-alerts-abc123

# --- Optional ---
# NODE_ENV=production
